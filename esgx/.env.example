# ESGX environment variables
# Copy this file to .env.local and fill in a key.
# Keys are used ONLY server-side (API routes); they never reach the browser.

# Option 1 (FREE — recommended for the hackathon):
# Create a free key at https://aistudio.google.com (no card required).
GEMINI_API_KEY=your_gemini_key_here

# Optional override (defaults to gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash

# Option 2 (paid, prepaid credits required):
# ANTHROPIC_API_KEY=your_api_key_here

# With NO keys at all: the dashboard, live news collection, and a
# mechanical keyword classifier still work — only LLM-quality
# classification and the AI Analyst summary are unavailable.
